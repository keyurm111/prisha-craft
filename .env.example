# Docker host ports
BACKEND_PORT=5000
CLIENT_PORT=5173
ADMIN_PORT=5174

# Backend runtime
NODE_ENV=production
MONGODB_URI=
JWT_SECRET=
JWT_EXPIRE=30d
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Frontend build-time values
VITE_API_URL=/api/v1
VITE_BACKEND_URL=http://server:5000
VITE_GOOGLE_CLIENT_ID=

# External integrations
GOOGLE_CLIENT_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_PICKUP_POSTCODE=110001
